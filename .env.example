# Mistral Worldwide Hackathon — InnerPlay
# ------------------------------------------
# Required: Mistral API key (mistral.ai)
MISTRAL_API_KEY=

# Required: ElevenLabs API key (elevenlabs.io)
ELEVENLABS_API_KEY=

# Required: ElevenLabs agent ID (create agent at elevenlabs.io/app/convai)
# Set custom LLM webhook URL = https://<your-vercel-domain>/api/llm
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Story files are loaded automatically from ./stories/<story-id>/
# No path configuration needed — the engine resolves stories dynamically.
